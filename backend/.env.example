# Database
POSTGRES_USER=foodstore
POSTGRES_PASSWORD=foodstore_dev_pass_123
POSTGRES_DB=foodstore_db
DATABASE_URL=postgresql://foodstore:foodstore_dev_pass_123@localhost:5432/foodstore_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_MINUTES=15

# FastAPI
DEBUG=true
APP_NAME=Food Store API
APP_VERSION=0.1.0
API_PREFIX=/api/v1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:5173

# Integraciones futuras segun especificacion v6
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_NOTIFICATION_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
